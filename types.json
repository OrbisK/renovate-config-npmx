{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Add npmx.dev types badge to Renovate PR bodies",
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "prBodyDefinitions": {
        "npmx types": "[![types](https://npmx.dev/api/registry/badge/types/{{depName}})](https://npmx.dev/package/{{depName}})"
      },
      "prBodyColumns": ["Package", "Change", "Age", "Confidence", "npmx types"]
    }
  ]
}
