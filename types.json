{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Add npmx.dev types badge to Renovate PR bodies",
  "prBodyDefinitions": {
    "npmx types": "[![types](https://npmx.dev/api/registry/badge/types/{{depName}})](https://npmx.dev/package/{{depName}})"
  },
  "prBodyColumns": ["Package", "Type", "Update", "Change", "npmx types"]
}
