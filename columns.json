{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Define all npmx.dev badge columns for use by other presets",
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "prBodyDefinitions": {
        "npmx": "[![size](https://npmx.dev/api/registry/badge/size/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}}) [![dependencies](https://npmx.dev/api/registry/badge/dependencies/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx version": "[![version](https://npmx.dev/api/registry/badge/version/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx license": "[![license](https://npmx.dev/api/registry/badge/license/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx size": "[![size](https://npmx.dev/api/registry/badge/size/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx downloads": "[![downloads](https://npmx.dev/api/registry/badge/downloads/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx downloads-day": "[![downloads-day](https://npmx.dev/api/registry/badge/downloads-day/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx downloads-week": "[![downloads-week](https://npmx.dev/api/registry/badge/downloads-week/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx downloads-month": "[![downloads-month](https://npmx.dev/api/registry/badge/downloads-month/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx downloads-year": "[![downloads-year](https://npmx.dev/api/registry/badge/downloads-year/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx vulnerabilities": "[![vulnerabilities](https://npmx.dev/api/registry/badge/vulnerabilities/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx dependencies": "[![dependencies](https://npmx.dev/api/registry/badge/dependencies/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx created": "[![created](https://npmx.dev/api/registry/badge/created/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx updated": "[![updated](https://npmx.dev/api/registry/badge/updated/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx engines": "[![engines](https://npmx.dev/api/registry/badge/engines/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx types": "[![types](https://npmx.dev/api/registry/badge/types/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx maintainers": "[![maintainers](https://npmx.dev/api/registry/badge/maintainers/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx deprecated": "[![deprecated](https://npmx.dev/api/registry/badge/deprecated/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx name": "[![name](https://npmx.dev/api/registry/badge/name/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})",
        "npmx likes": "[![likes](https://npmx.dev/api/registry/badge/likes/{{depName}}?style=shieldsio)](https://npmx.dev/package/{{depName}})"
      }
    }
  ]
}
