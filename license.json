{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Add npmx.dev license badge to Renovate PR bodies",
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "prBodyDefinitions": {
        "npmx license": "[![license](https://npmx.dev/api/registry/badge/license/{{depName}})](https://npmx.dev/package/{{depName}})"
      },
      "prBodyColumns": ["Package", "Change", "Age", "Confidence", "npmx license"]
    }
  ]
}
