{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Add npmx.dev downloads badge to Renovate PR bodies",
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "prBodyDefinitions": {
        "npmx downloads": "[![downloads](https://npmx.dev/api/registry/badge/downloads/{{depName}})](https://npmx.dev/package/{{depName}})"
      },
      "prBodyColumns": ["Package", "Change", "Age", "Confidence", "npmx downloads"]
    }
  ]
}
