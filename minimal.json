{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Add essential npmx.dev badges (vulnerabilities, size, types) to Renovate PR bodies",
  "extends": ["github>OrbisK/renovate-config-npmx:columns"],
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "prBodyDefinitions": {
        "npmx": "[![vulnerabilities](https://npmx.dev/api/registry/badge/vulnerabilities/{{depName}})](https://npmx.dev/package/{{depName}}) [![size](https://npmx.dev/api/registry/badge/size/{{depName}})](https://npmx.dev/package/{{depName}}) [![types](https://npmx.dev/api/registry/badge/types/{{depName}})](https://npmx.dev/package/{{depName}})"
      },
      "prBodyColumns": ["Package", "Change", "Age", "Confidence", "npmx"]
    }
  ]
}