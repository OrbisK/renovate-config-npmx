{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Add npmx.dev size badge to Renovate PR bodies",
  "prBodyDefinitions": {
    "npmx size": "[![size](https://npmx.dev/api/registry/badge/size/{{depName}})](https://npmx.dev/package/{{depName}})"
  },
  "prBodyColumns": ["Package", "Type", "Update", "Change", "npmx size"]
}
