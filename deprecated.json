{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Add npmx.dev deprecated badge to Renovate PR bodies",
  "prBodyDefinitions": {
    "npmx deprecated": "[![deprecated](https://npmx.dev/api/registry/badge/deprecated/{{depName}})](https://npmx.dev/package/{{depName}})"
  },
  "prBodyColumns": ["Package", "Type", "Update", "Change", "npmx deprecated"]
}
